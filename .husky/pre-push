#!/usr/bin/env sh

# --- Java: SpotBugs (run only when backend Java files changed vs remote) ---
REMOTE_REF=$(git rev-parse @{upstream} 2>/dev/null || git rev-parse origin/main 2>/dev/null)
if [ -n "$REMOTE_REF" ]; then
  JAVA_CHANGED=$(git diff --name-only "$REMOTE_REF"..HEAD -- 'backend/src/main/**/*.java' | head -1)
else
  JAVA_CHANGED=$(git diff --name-only HEAD~1..HEAD -- 'backend/src/main/**/*.java' | head -1)
fi

if [ -n "$JAVA_CHANGED" ]; then
  echo "[pre-push] Running SpotBugs on backend..."
  cd backend && ./gradlew spotbugsMain --quiet
  SPOTBUGS_EXIT=$?
  cd ..
  if [ $SPOTBUGS_EXIT -ne 0 ]; then
    echo "[pre-push] SpotBugs failed. Please fix the violations before pushing."
    exit 1
  fi
fi

# --- Frontend: ESLint (full project check) ---
if [ -n "$REMOTE_REF" ]; then
  FE_CHANGED=$(git diff --name-only "$REMOTE_REF"..HEAD -- 'frontend/src/**/*.ts' 'frontend/src/**/*.vue' | head -1)
else
  FE_CHANGED=$(git diff --name-only HEAD~1..HEAD -- 'frontend/src/**/*.ts' 'frontend/src/**/*.vue' | head -1)
fi

if [ -n "$FE_CHANGED" ]; then
  echo "[pre-push] Running ESLint on frontend..."
  cd frontend && npx eslint . --max-warnings 0
  ESLINT_EXIT=$?
  cd ..
  if [ $ESLINT_EXIT -ne 0 ]; then
    echo "[pre-push] ESLint failed. Please fix the errors before pushing."
    exit 1
  fi
fi
