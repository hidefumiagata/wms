{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:api": "openapi-generator-cli generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,json,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,json,css,scss}\""
  },
  "dependencies": {
    "@vee-validate/zod": "^4.15.1",
    "axios": "^1.13.6",
    "element-plus": "^2.13.6",
    "pinia": "^3.0.4",
    "sass": "^1.98.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.30",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@eslint/js": "^10.0.1",
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@pinia/testing": "^1.0.3",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.8",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.1",
    "vue-tsc": "^3.2.5"
  }
}
