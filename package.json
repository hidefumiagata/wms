{
  "name": "wms",
  "version": "1.0.0",
  "private": true,
  "description": "WMS ShowCase Project - root workspace for git hooks",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,vue}": [
      "bash -c 'cd frontend && npx eslint --no-warn-ignored \"$@\"' --",
      "bash -c 'cd frontend && npx prettier --check \"$@\"' --"
    ],
    "frontend/src/**/*.{json,css,scss}": [
      "bash -c 'cd frontend && npx prettier --check \"$@\"' --"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hidefumiagata/wms.git"
  }
}
